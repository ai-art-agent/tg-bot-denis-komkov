# Скопируйте этот файл в .env и заполните значения.
# Файл .env не публикуйте и не добавляйте в репозиторий.

TELEGRAM_BOT_TOKEN=ваш_токен_от_BotFather
DEEPSEEK_API_KEY=ваш_ключ_DeepSeek

# Опционально: отдельный ключ DeepSeek для валидатора (рекомендуется при нагрузке — разводит лимиты RPM/TPM)
# Если не задан, валидатор использует DEEPSEEK_API_KEY. Подробно: INSTRUCTIONS.md, раздел «Два ключа DeepSeek».
# DEEPSEEK_API_KEY_VALIDATOR=второй_ключ_DeepSeek

# Опционально: для распознавания голосовых сообщений (OpenAI Whisper)
# OPENAI_API_KEY=ваш_ключ_OpenAI

# Модель DeepSeek: температура (0.0–2.0, по умолчанию 1.75) и макс. токенов ответа (по умолчанию 4800).
# DEEPSEEK_TEMPERATURE=1.75
# DEEPSEEK_MAX_TOKENS=4800

# ===================== Robokassa (оплата) =====================
# Данные мерчанта Robokassa (берутся в личном кабинете Robokassa)
ROBOKASSA_MERCHANT_LOGIN=ai_psychologist

# Боевые пароли (для ROBOKASSA_IS_TEST=0): Пароль №1 и Пароль №2 из раздела «Продажа» личного кабинета Robokassa.
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=

# Тестовые пароли (для ROBOKASSA_IS_TEST=1): Пароль №1 и Пароль №2 из блока «Тестовый режим» вкладки «Технические настройки». Если заданы — используются вместо боевых при IsTest=1.
ROBOKASSA_PASSWORD1_TEST=
ROBOKASSA_PASSWORD2_TEST=

# Куда строить ссылку оплаты (обычно можно оставить по умолчанию)
ROBOKASSA_MERCHANT_URL=https://auth.robokassa.ru/Merchant/Index.aspx

# Тестовый режим (1 = IsTest=1 в ссылке, используются ROBOKASSA_PASSWORD1_TEST/ROBOKASSA_PASSWORD2_TEST при наличии, иначе ROBOKASSA_PASSWORD1/2).
# См. https://docs.robokassa.ru/ru/testing-mode
ROBOKASSA_IS_TEST=1

# Где хранить реестр заказов (SQLite). Для VPS/VM подходит отлично.
# Для serverless лучше внешняя БД, но эта настройка даст рабочий старт.
PAYMENTS_DB_PATH=payments.sqlite3

# Имя бота без @ (например denis_komkov_bot). Нужно для страниц успеха/ошибки оплаты (robokassa-server): кнопка «Открыть чат» и автопереход в Telegram на мобильных.
TELEGRAM_BOT_USERNAME=denis_komkov_bot

# Куда слать дайджест по оплатившим групповые занятия (два режима). chat_id личного аккаунта или группы (число) либо @username канала (например @cogito163). Для личного аккаунта обязательно укажите число (узнать: getUpdates после сообщения боту), иначе уведомления не дойдут.
TELEGRAM_GROUP_NOTIFY_CHAT_ID=

# Режим отправки дайджеста: immediate — сразу при каждой оплате в этот чат; scheduled — по расписанию (см. ниже).
GROUP_DIGEST_MODE=scheduled

# При GROUP_DIGEST_MODE=scheduled — время отправки по Москве (HH:MM). Пустое поле = слот не используется (можно 1–3 раза в сутки).
GROUP_DIGEST_TIME_1=12:00
GROUP_DIGEST_TIME_2=16:00
GROUP_DIGEST_TIME_3=

# При scheduled: за сколько часов от «сейчас» выбирать оплаты (число, по умолчанию 12).
GROUP_DIGEST_SINCE_HOURS=12

# Цены (можно менять без правок кода). Бот и промпты берут их только из .env при запуске.
# Формат: целое или с точкой (2990 или 2990.00) — код нормализует для Робокассы; оба варианта допустимы.
# Групповые занятия — два тарифа (если задать только PRICE_GROUP_RUB, он будет использован для обоих тарифов).
PRICE_GROUP_STANDARD_RUB=24990.00
PRICE_GROUP_VIP_RUB=45990.00
PRICE_WEBINAR_RUB=2990.00
# AI-Психолог Pro: по предзаказу и после запуска (для бота и мини-приложения)
PRICE_PRO_RUB=990.00
PRICE_PRO_OPEN_RUB=1990.00

# Личная работа 1-на-1 (три варианта; мини-приложение и Robokassa):
# 1 месяц плотной личной работы
PRICE_PERSONAL_1M_RUB=120000.00
# 2 месяца глубокой перестройки
PRICE_PERSONAL_2M_RUB=180000.00
# 4 месяца VIP-сопровождения
PRICE_PERSONAL_4M_RUB=300000.00

# URL мини-приложения: выбор формата и оплата после «Хочу продолжить».
# Telegram открывает Web App внутри чата только по HTTPS. Как получить HTTPS без домена: см. MINIAPP_HTTPS.md (Cloudflare Tunnel).
# Примеры: https://ваш-хостнейм/miniapp  или  http://IP:8000/miniapp (откроется в браузере).
MINIAPP_URL=

# Ссылки, которые выдаём после подтверждения оплаты (ResultURL):
WEBINAR_ACCESS_URL=https://t.me/denis_komkov_bot
GROUP_COURSE_ACCESS_URL=https://t.me/denis_komkov_bot
PRO_BOT_URL=https://t.me/denis_komkov_bot
