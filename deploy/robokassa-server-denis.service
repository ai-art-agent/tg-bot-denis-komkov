[Unit]
Description=Robokassa HTTP server for Denis Komkov miniapp (miniapp + create_order on Denis's Robokassa)
After=network.target

[Service]
Type=simple
User=enhel-method
WorkingDirectory=/home/enhel-method/tg-ai-denis-komkov
Environment=PATH=/home/enhel-method/tg-ai-denis-komkov/venv/bin
Environment=TZ=Europe/Moscow
EnvironmentFile=/home/enhel-method/tg-ai-denis-komkov/.env
ExecStart=/home/enhel-method/tg-ai-denis-komkov/venv/bin/uvicorn robokassa_server:app --host 0.0.0.0 --port 8001 --http h11
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
